name: superzent
title: superzent
base: core24
version: "$RELEASE_VERSION"
summary: The terminal shell for coding agents
description: |
  Superzent is a native workspace shell for coding agents with an integrated
  editor, terminal, and diff workflow.
grade: stable
confinement: classic
compression: lzo
website: https://github.com/currybab/superzent
source-code: https://github.com/currybab/superzent
issues: https://github.com/currybab/superzent/issues
contact: https://github.com/currybab/superzent/discussions

parts:
  superzent:
    plugin: dump
    source: "https://github.com/currybab/superzent/releases/download/v$RELEASE_VERSION/superzent-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it superzent exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it superzent exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  superzent:
    command: usr/bin/superzent
    common-id: ai.nangman.superzent
    environment:
      ZED_BUNDLE_TYPE: snap
